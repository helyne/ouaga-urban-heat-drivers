# =============================================================================
# git archive export-ignore rules
#
# Files listed here stay in git for collaborators but are excluded from the
# submission zip produced by `git archive -o submission.zip HEAD`.
# =============================================================================

# Legacy/exploratory notebooks — not needed for reproduction
notebooks/00_quick_start.ipynb          export-ignore
notebooks/02_eda.ipynb                  export-ignore
notebooks/download_individual_bands.ipynb  export-ignore
notebooks/models.ipynb                  export-ignore
notebooks/DEM/                          export-ignore
notebooks/Distance_measures/            export-ignore
notebooks/Heatwave/                     export-ignore
notebooks/Hotspots/                     export-ignore
notebooks/NDVI_NDBI_BSI/                export-ignore

# Documentation and presentations — not needed for reproduction
CONTRIBUTING.md                         export-ignore
documentation/                          export-ignore
presentations/                          export-ignore
reports/                                export-ignore

# Generated HTML maps — too large, regenerated by notebooks
figures/*.html                          export-ignore

# Duplicate/unnecessary data files
"data/raw/Shapefile Ouaga/Ouaga.zip"              export-ignore
"data/raw/Shapefile Ouaga/ougadougou_shapefile.ipynb"  export-ignore
